# Copy to .env.development and adjust values.
# MONGO_URI must start with mongodb:// or mongodb+srv://

# MONGO_URI=mongodb://127.0.0.1:27017/jitox
# PORT=4000
# JWT_SECRET_KEY=change-me-to-a-long-random-string

# Seed users once (idempotent): open or curl GET http://localhost:4000/users/get-users
# Requires NODE_ENV=development (npm run dev) or ALLOW_BOOTSTRAP_USERS=true.
# Creates if missing only — password for all three: 123456
#   admin@gmail.com     — Admin
#   manager@gmail.com   — Manager
#   testuser@gmail.com  — User
# ALLOW_BOOTSTRAP_USERS=true

# Demo data for UI testing (products, accounts, tasks, vouchers, day book, etc.)
# Runs automatically on `npm run dev` unless disabled. Idempotent — safe to restart.
# SEED_DEMO_DATA=false

# Dev-only: include OTP in JSON for /users/send-otp when email is not configured
# EXPOSE_OTP_IN_DEV=true

# Optional — only if you use email features
# EMAIL_USER=
# EMAIL_PASS=
