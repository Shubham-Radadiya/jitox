# Copy to .env.production for production runs (npm start).

# MONGO_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/jitox
# PORT=4000
# JWT_SECRET_KEY=use-a-long-random-secret

# Never enable unless you understand the risk (seeds default admin/user).
# ALLOW_BOOTSTRAP_USERS=false

# Required on Render for OTP emails (Gmail → App passwords)
# EMAIL_USER defaults to shubhamradadiya@gmail.com if unset
EMAIL_USER=shubhamradadiya@gmail.com
EMAIL_PASS=your-gmail-app-password
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
