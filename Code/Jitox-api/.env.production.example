# Copy to .env.production for production runs (npm start).

# MONGO_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/jitox
# PORT=4000
# JWT_SECRET_KEY=use-a-long-random-secret
# CORS_ORIGINS=https://jitox.vercel.app

EMAIL_USER=shubhamradadiya@gmail.com
# EMAIL_SENDER_NAME=Jitox Agro

# --- Render / production (recommended): Gmail API over HTTPS ---
# Render FREE blocks SMTP ports 587/465. Use OAuth + Gmail API instead:
# 1. Google Cloud: enable Gmail API, OAuth Desktop client
# 2. npm run gmail:oauth  → copy GMAIL_REFRESH_TOKEN
EMAIL_TRANSPORT=auto
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token-from-gmail-oauth-script

# --- Local dev only: Gmail SMTP (optional if GMAIL_* is set) ---
# EMAIL_PASS=your-16-char-gmail-app-password
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
