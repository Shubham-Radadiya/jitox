# Copy to .env.local (or .env) — Vite exposes only variables prefixed with VITE_.

VITE_API_BASE_URL=http://localhost:4000

# --- Vercel production (Project → Settings → Environment Variables) ---
# VITE_API_BASE_URL=https://jitox.onrender.com
# VITE_SITE_URL=https://jitox.vercel.app

# Public site URL (no trailing slash) — canonical, Open Graph, sitemap
VITE_SITE_URL=https://jitox.vercel.app

# Optional: Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# VITE_GA_MEASUREMENT_ID=

# Optional: Google Search Console HTML tag verification content value only
# VITE_GSC_VERIFICATION=
